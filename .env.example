# Friendarr environment variables
# Copy this file to .env and adjust values

# Listen port (default: 5056)
PORT=5056

# Master API key — required for managing API keys, also works as a regular API key
API_KEY=

# Root directory for media libraries (default: /media)
LIBRARY_BASE_PATH=/media

# Temporary download directory (default: /tmp/friendarr)
TEMP_DIR=/tmp/friendarr

# Max parallel downloads (default: 2)
MAX_CONCURRENT_DOWNLOADS=2
