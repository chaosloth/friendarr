# Friendarr environment variables
# Copy this file to .env and adjust values

# Listen port (default: 5056)
PORT=5056

# Master API key — required for managing API keys, also works as a regular API key
API_KEY=

# Directory for in-progress downloads (default: /downloads/incomplete)
# Files are downloaded here first, then hard-linked to the completed path on success
INCOMPLETE_PATH=/downloads/incomplete

# Root directory for completed media (default: /downloads/complete)
# Movies are placed in <path>/movies/, TV in <path>/tv/
COMPLETED_PATH=/downloads/complete

# Custom directory for movies (default: empty → falls back to COMPLETED_PATH/movies)
# MOVIE_PATH=

# Custom directory for TV shows (default: empty → falls back to COMPLETED_PATH/tv)
# TV_PATH=

# Max parallel downloads (default: 2)
MAX_CONCURRENT_DOWNLOADS=2

# Enable debug logging (default: false)
# DEBUG=true

# Maximum number of log entries to keep in memory (default: 500)
# LOG_BUFFER_SIZE=500

# Path for persistent data like API keys (default: ./config)
# DATA_DIR=/app/config
